{
  "pluginAlias": "LutronLeap",
  "pluginType": "platform",
  "singular": true,
  "schema": {
    "type": "object",
    "properties": {
      "name": {
        "title": "Name",
        "type": "string",
        "default": "Lutron Homeworks QSX"
      },
      "host": {
        "title": "IP address of Homeworks QSX",
        "type": "string",
        "required": true
      },
      "port": {
        "title": "LEAP port",
        "type": "integer",
        "default": 8081
      },
      "username": {
        "title": "Username",
        "type": "string",
        "default": "admin"
      },
      "password": {
        "title": "Password",
        "type": "string"
      },
      "useTLS": {
        "title": "Use TLS (port 8083)",
        "type": "boolean",
        "default": false
      },
      "pollInterval": {
        "title": "Poll interval (seconds)",
        "type": "integer",
        "default": 30
      }
    }
  },
  "layout": [
    "name", "host", "port", "username", "password", "useTLS", "pollInterval"
  ]
}
